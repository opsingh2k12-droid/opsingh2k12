# ============================================
# BillDesk Pro — Production Environment
# billdesk.wifiwalanet.in
# ============================================
# Lives ALONGSIDE trade.wifiwalanet.in on same VPS.
# Uses port 3001 + separate SQLite DB file.

# ---------- App ----------
NODE_ENV=production
PORT=3001
HOSTNAME=0.0.0.0

# ---------- NextAuth ----------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=CHANGE_ME_GENERATE_32_CHAR_RANDOM_STRING
NEXTAUTH_URL=https://billdesk.wifiwalanet.in

# ---------- Database ----------
# Separate DB file (does NOT touch trade app's DB)
DATABASE_URL=file:/opt/billdesk/db/production.db

# ---------- Optional: Email ----------
RESEND_API_KEY=
EMAIL_FROM="BillDesk Pro <noreply@billdesk.wifiwalanet.in>"

# ---------- Optional: Razorpay ----------
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ---------- Optional: WhatsApp Business API ----------
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# ---------- App config ----------
APP_NAME="BillDesk Pro"
SUPPORT_EMAIL=support@wifiwalanet.in
TRIAL_DAYS=14

# ---------- File uploads (logos, signatures) ----------
# Persistent directory outside .next (survives rebuilds)
UPLOAD_DIR=/opt/billdesk/uploads
